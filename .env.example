# =============================================================================
# BRIN — متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env.local (بدون رفعه لـ Git) واملأ القيم الفعلية هناك.
# لا تضع أي قيمة حساسة حقيقية بهذا الملف.
# =============================================================================

# --- Supabase ---
# NEXT_PUBLIC_* تُستخدم بمتصفح العميل (موقع المنيو فقط) — آمنة للعرض العام
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# سري بالكامل — يُستخدم فقط داخل Server Actions / Route Handlers (يتجاوز RLS)
SUPABASE_SERVICE_ROLE_KEY=

# --- Moyasar (الدفع الإلكتروني) ---
MOYASAR_SECRET_KEY=
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_WEBHOOK_SECRET=

# --- Authentica (OTP عبر SMS للعملاء) ---
AUTHENTICA_API_KEY=
AUTHENTICA_BASE_URL=

# --- جلسة الموظفين (دخول PIN، جلسة مخصصة خارج Supabase Auth) ---
EMPLOYEE_SESSION_SECRET=

# --- روابط المواقع الثلاثة (تُستخدم للربط بينها ولإعدادات CORS/Redirects) ---
NEXT_PUBLIC_MENU_URL=
NEXT_PUBLIC_POS_URL=
NEXT_PUBLIC_ADMIN_URL=

# --- Print Agent (يعمل محلياً على جهاز الكاشير) ---
PRINT_AGENT_URL=
PRINT_AGENT_API_KEY=

# --- عام ---
NODE_ENV=development
